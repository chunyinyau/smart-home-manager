# --- SMART HOME MANAGER ENV TEMPLATE ---
# Copy this to .env and fill in your values.

# Backend database URLs are managed inside docker-compose.yml.
# Docker automatically injects them into the containers.
# You do NOT need to set database URLs here.

# If you add frontend-specific env vars (e.g. API keys), put them below:
# NEXT_PUBLIC_EXAMPLE_KEY="your-value"

# RabbitMQ configuration for History async event ingestion.
# If omitted, the app tries localhost, 127.0.0.1, then rabbitmq (Docker service name).
# RABBITMQ_URL="amqp://guest:guest@localhost:5672"
# RABBITMQ_URLS="amqp://guest:guest@localhost:5672,amqp://guest:guest@rabbitmq:5672"
# HISTORY_EVENTS_QUEUE="history.events.v1"