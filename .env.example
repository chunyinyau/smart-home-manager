# --- SMART HOME MANAGER ENV TEMPLATE ---
# Copy this to .env and fill in your values.

# Backend database URLs are managed inside docker-compose.yml.
# Docker automatically injects them into the containers.
# You do NOT need to set database URLs here.

# If you add frontend-specific env vars (e.g. API keys), put them below:
# NEXT_PUBLIC_EXAMPLE_KEY="your-value"

# Optional alias if you already use OpenAI naming convention:
# OPENAI_API_KEY=your_api_key

# Optional: exact public endpoints for OpenClaw/Telegram flows via Kong + ngrok.
# Use the {userId} placeholder if your updatebudget gateway route expects the user id in the path.
# Example:
# OPENCLAW_UPDATE_BUDGET_URL="https://abc123.ngrok-free.app/updatebudget/api/updatebudget/{userId}"
# OPENCLAW_REQUEST_CHANGE_URL="https://abc123.ngrok-free.app/request-change/api/request-change"
# OPENCLAW_CHANGE_APPLIANCE_STATE_URL="https://abc123.ngrok-free.app/change-appliance-state/api/change-appliance-state"
OPENCLAW_UPDATE_BUDGET_URL=
OPENCLAW_REQUEST_CHANGE_URL=
OPENCLAW_CHANGE_APPLIANCE_STATE_URL=
