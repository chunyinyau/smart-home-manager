generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("BUDGET_DATABASE_URL")
}

model Budget {
  budget_id  Int     @id @default(autoincrement())
  user_id    Int     @unique // References the User 
  budget_cap Decimal @db.Decimal(10, 2) // Monthly cap set by user 
  cum_bill   Decimal @db.Decimal(10, 2) // Dumped from last month's calculation 

  @@map("budget")
}

model Bill {
  bill_id              Int      @id @default(autoincrement())
  user_id              Int      // References the User [cite: 11]
  period_kwh           Decimal  @db.Decimal(12, 4) // Total kWh used in 15-min window 
  period_cost_sgd      Decimal  @db.Decimal(12, 4) // Cost for this 15-min period 
  computed_at          DateTime @default(now())   // Timestamp of calculation run 
  billing_period_start DateTime @db.Date          // Detect month rollover 

  @@map("bill")
}