generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("RATE_DATABASE_URL")
}

model Rate {
  rate_id        Int      @id @default(autoincrement())
  cents_per_kwh  Decimal  @db.Decimal(10, 4)
  month_year     String   @db.VarChar(7)  // e.g. "2026-03"
  
  @@map("rates")
}
